DATABASE_URL=postgresql+psycopg://tutor:tutor@localhost:55432/tutor
DEBUG=True
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:4173","http://localhost:5173"]
API_KEYS=["local-dev-key"]
DEFAULT_AUTH_USER_ID=local
MAX_UPLOAD_SIZE_MB=25

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4-turbo-preview
DEFAULT_LLM_PROVIDER=auto
ALLOW_GLOBAL_LLM_FALLBACK=True
JWT_SECRET=
COOKIE_SAMESITE=strict
COOKIE_SECURE=
LLM_CREDENTIAL_ENCRYPTION_KEY=
LLM_CREDENTIAL_PREVIOUS_KEYS=
LLM_FINGERPRINT_HMAC_KEY=
# Generate LLM_CREDENTIAL_ENCRYPTION_KEY with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Never commit real provider API keys or credential encryption keys.

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

LINKAPI_API_KEY=
LINKAPI_BASE_URL=https://api.linkapi.ai/v1
LINKAPI_MODEL=claude-sonnet-4-20250514

RAG_UPLOAD_DIR=storage/materials
RAG_CHUNK_SIZE=1200
RAG_CHUNK_OVERLAP=150
RAG_TOP_K=5
RAG_VECTOR_DIM=1536
RAG_HNSW_EF_SEARCH=40
# Embedding provider: "openai" (production) or "hash" (deterministic local vectors for tests/CI)
RAG_EMBEDDING_MODE=openai
RAG_EMBEDDING_API_KEY=
RAG_EMBEDDING_BASE_URL=https://api.openai.com/v1
RAG_EMBEDDING_MODEL=text-embedding-3-small
